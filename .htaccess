# UniDorm/.htaccess

DirectoryIndex index.php

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /UniDorm/

    # Bỏ qua file và thư mục thực
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Chuyển tất cả route còn lại vào index.php
    RewriteRule ^(.*)$ index.php?page=$1 [QSA,L]
</IfModule>