RewriteEngine On
RewriteBase /

# Đặt index.php làm trang mặc định
DirectoryIndex index.php index.html

# Tắt Directory Listing
Options -Indexes

# Bỏ qua file thực tế tồn tại (assets, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Tất cả route → index.php (ngoại trừ /api/)
RewriteRule ^(?!api/)(.*)$ index.php?page=$1 [QSA,L]