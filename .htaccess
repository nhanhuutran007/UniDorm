# UniDorm/.htaccess

DirectoryIndex index.php

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Khi chạy thật trên domain chính, base là /
    # Chú ý: Nếu chạy localhost dạng http://localhost/UniDorm/ thì vẫn cần RewriteBase /UniDorm/
    # RewriteBase /

    # Bỏ qua file và thư mục thực
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Chuyển tất cả route còn lại vào index.php
    RewriteRule ^(.*)$ index.php?page=$1 [QSA,L]
</IfModule>